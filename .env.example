# SAP AI Core Credentials
# Copy this file to .env and fill in your credentials

# OAuth Client ID from SAP AI Core service binding
SAP_AI_CORE_CLIENT_ID=your_client_id

# OAuth Client Secret from SAP AI Core service binding
SAP_AI_CORE_CLIENT_SECRET=your_client_secret

# OAuth Token URL from SAP AI Core service binding
# Usually looks like: https://your-tenant.authentication.eu10.hana.ondemand.com
SAP_AI_CORE_TOKEN_URL=https://your-tenant.authentication.region.hana.ondemand.com

# SAP AI Core API Base URL from service binding
# Usually looks like: https://api.ai.internalprod.eu-central-1.aws.ml.hana.ondemand.com
SAP_AI_CORE_BASE_URL=https://api.ai.your-region.aws.ml.hana.ondemand.com

# Resource Group (optional, default: "default")
SAP_AI_CORE_RESOURCE_GROUP=default

# Proxy Server Configuration
PORT=3000

# Log Level (debug, info, warn, error)
LOG_LEVEL=info