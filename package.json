  "description": "SAP AI Core LLM Proxy - OpenAI compatible API proxy for SAP AI Core",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
